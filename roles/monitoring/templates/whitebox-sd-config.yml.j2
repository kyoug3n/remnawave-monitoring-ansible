{% for key in whitebox_targets | default([]) %}
{% set protocol = key | regex_search('^([a-z]+)://', '\\1') | first | default('unknown') %}
{% set key_name = key | regex_search('#(.+)$', '\\1') | first | default('') %}
{% set client = (protocol + '-' + key_name) if key_name else protocol %}
- targets: ["https://google.com"]
  labels:
    ctx: "{{ key }}"
    client: "{{ client }}"
    protocol: "{{ protocol }}"
{% endfor %}
