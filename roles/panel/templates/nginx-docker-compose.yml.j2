services:
  remnawave-nginx:
    image: nginx:1.28
    container_name: remnawave-nginx
    hostname: remnawave-nginx
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - ./fullchain.pem:/etc/nginx/ssl/fullchain.pem:ro
      - ./privkey.key:/etc/nginx/ssl/privkey.key:ro
{% if remnawave_secret_header_enabled %}
      - ./nexus.html:/usr/share/nginx/html/nexus.html:ro
{% endif %}
    restart: always
    ports:
      - '0.0.0.0:{{ remnawave_nginx_https_port }}:443'
    networks:
      - {{ remnawave_network_name }}

networks:
  {{ remnawave_network_name }}:
    name: {{ remnawave_network_name }}
    external: true
