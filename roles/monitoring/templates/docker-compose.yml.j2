services:
  prometheus:
    image: prom/prometheus:latest
    container_name: prometheus
    hostname: prometheus
    volumes:
      - ./prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - ./whitebox-sd-config.yml:/etc/prometheus/whitebox-sd-config.yml:ro
      - prometheus_data:/prometheus
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
      - '--web.enable-lifecycle'
    restart: always
    ports:
      - '127.0.0.1:{{ prometheus_port }}:9090'
    networks:
      - {{ monitoring_network_name }}

  blackbox:
    image: prom/blackbox-exporter:latest
    container_name: blackbox
    hostname: blackbox
    restart: unless-stopped
    ports:
      - '127.0.0.1:{{ blackbox_port }}:9115'
    command:
      - '--config.file=/etc/blackbox/blackbox.yml'
    volumes:
      - ./blackbox.yml:/etc/blackbox/blackbox.yml:ro
    networks:
      - {{ monitoring_network_name }}

  whitebox:
    image: rxyvea/whitebox:latest
    container_name: whitebox
    hostname: whitebox
    restart: unless-stopped
    ports:
      - '127.0.0.1:{{ whitebox_port }}:9116'
    command:
      - '--config.file=/etc/whitebox/whitebox.yml'
    volumes:
      - ./whitebox.yml:/etc/whitebox/whitebox.yml:ro
    networks:
      - {{ monitoring_network_name }}

  grafana:
    image: grafana/grafana:latest
    container_name: grafana
    hostname: grafana
    env_file:
      - .env
    volumes:
      - grafana_data:/var/lib/grafana
      - ./provisioning/datasources:/etc/grafana/provisioning/datasources:ro
      - ./provisioning/dashboards:/etc/grafana/provisioning/dashboards:ro
      - ./dashboards:/var/lib/grafana/dashboards:ro
    restart: always
    ports:
      - '127.0.0.1:{{ grafana_port }}:3000'
    networks:
      - {{ monitoring_network_name }}
    depends_on:
      - prometheus

volumes:
  prometheus_data:
  grafana_data:

networks:
  {{ monitoring_network_name }}:
    name: {{ monitoring_network_name }}
    driver: bridge
